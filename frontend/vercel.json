{
  "buildCommand": "node scripts/prepare-vercel.mjs && npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/api/cron/process-queue",
      "schedule": "*/3 * * * *"
    },
    {
      "path": "/api/cron/process-pending",
      "schedule": "*/10 * * * *"
    }
  ]
}
